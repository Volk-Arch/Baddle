# IDE / venv / build
.idea/
.venv/
.claude/
models/
llama-server/
__pycache__/
Article/
*.pyc
*.pyo

# Runtime data dir — settings, user_state, user_profile, goals, activity,
# checkins, patterns, plans, legacy state_graph/embeddings/archive,
# roles/templates (copy of ship-defaults).
data/

# Per-workspace storage: graphs/<id>/graph.json + state_graph.jsonl +
# state_embeddings.jsonl + meta.json + solved/*. graphs/* — wildcard т.к.
# git не заглядывает внутрь ignored dir, поэтому «ignore everything except
# .gitkeep» требует звёздочку.
graphs/*
!graphs/.gitkeep

# Workspace index (список воркспейсов + cross_edges — user-specific)
workspaces/*
!workspaces/.gitkeep
