  "nodes": [
    {"id": 0, "text": "Baddle: AHI Protocol — как устроено мышление?", "depth": -1, "topic": "Baddle Architecture", "type": "goal", "confidence": 0.95, "entropy": {"avg": 0, "unc": 0}, "mode": "horizon"},

    {"id": 1, "text": "Active Inference (Фристон): мозг минимизирует surprise", "depth": 0, "topic": "Baddle Architecture", "type": "fact", "confidence": 0.9, "entropy": {"avg": 0, "unc": 0}},
    {"id": 2, "text": "CognitiveHorizon: precision → temperature, policy → фаза, surprise → обратная связь", "depth": 1, "topic": "Baddle Architecture", "type": "hypothesis", "confidence": 0.8, "entropy": {"avg": 0, "unc": 0}},
    {"id": 3, "text": "Высокий surprise → расширить горизонт (RECOVERY)", "depth": 2, "topic": "Baddle Architecture", "type": "evidence", "confidence": 0.85, "entropy": {"avg": 0, "unc": 0}},
    {"id": 4, "text": "Низкий surprise → сузить фокус (EXECUTION)", "depth": 2, "topic": "Baddle Architecture", "type": "evidence", "confidence": 0.85, "entropy": {"avg": 0, "unc": 0}},

    {"id": 5, "text": "Байесовский мозг: вероятности, не факты", "depth": 0, "topic": "Baddle Architecture", "type": "fact", "confidence": 0.95, "entropy": {"avg": 0, "unc": 0}},
    {"id": 6, "text": "Confidence 0–1 на каждой ноде. Bayes update при evidence.", "depth": 1, "topic": "Baddle Architecture", "type": "hypothesis", "confidence": 0.9, "entropy": {"avg": 0, "unc": 0}},

    {"id": 7, "text": "Диалектика Гегеля: тезис → антитезис → синтез", "depth": 0, "topic": "Baddle Architecture", "type": "fact", "confidence": 0.95, "entropy": {"avg": 0, "unc": 0}},
    {"id": 8, "text": "Smart DC: 3 полюса → embedding centroid → synthesis. Confidence = cosine to centroid.", "depth": 1, "topic": "Baddle Architecture", "type": "hypothesis", "confidence": 0.9, "entropy": {"avg": 0, "unc": 0}},
    {"id": 9, "text": "Принудительный антитезис ломает эхо-камеры структурно", "depth": 2, "topic": "Baddle Architecture", "type": "evidence", "confidence": 0.9, "entropy": {"avg": 0, "unc": 0}},

    {"id": 10, "text": "Хеббовское обучение: что активируется вместе — связывается", "depth": 0, "topic": "Baddle Architecture", "type": "fact", "confidence": 0.95, "entropy": {"avg": 0, "unc": 0}},
    {"id": 11, "text": "transition_prob += lr × (1 - tp) при навигации пользователя", "depth": 1, "topic": "Baddle Architecture", "type": "hypothesis", "confidence": 0.85, "entropy": {"avg": 0, "unc": 0}},

    {"id": 12, "text": "Дивергенция/конвергенция (Гилфорд): расширение ↔ сужение", "depth": 0, "topic": "Baddle Architecture", "type": "fact", "confidence": 0.95, "entropy": {"avg": 0, "unc": 0}},
    {"id": 13, "text": "Generate (дивергенция) → Merge + Collapse (конвергенция) → повтор", "depth": 1, "topic": "Baddle Architecture", "type": "hypothesis", "confidence": 0.9, "entropy": {"avg": 0, "unc": 0}},

    {"id": 14, "text": "Рабочая память (Миллер, 7±2): не удержать 50 идей", "depth": 0, "topic": "Baddle Architecture", "type": "fact", "confidence": 0.95, "entropy": {"avg": 0, "unc": 0}},
    {"id": 15, "text": "Collapse сжимает N идей в 1 синтез — переход на уровень абстракции выше", "depth": 1, "topic": "Baddle Architecture", "type": "hypothesis", "confidence": 0.85, "entropy": {"avg": 0, "unc": 0}},

